+            const retryable = ['EBUSY', 'EPERM', 'EACCES', 'UNKNOWN'].includes(code) ||
+                message.includes('unknown error, open');
+            if (!retryable || attempt === retryDelays.length) {
+                throw err;
+            }
+            const delay = retryDelays[attempt];
+            (0, common_1.debug)(`resedit failed with ${code || message}; retrying in ${delay}ms`);
+            await wait(delay);
+        }
+    }
